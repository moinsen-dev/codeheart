# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Development Authentication
# Set to 'true' to enable development mode with quick login buttons and dev banner
# This is useful for local development and testing different user roles
NEXT_PUBLIC_DEV_AUTH=false

# Supabase (for future use)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe (for future use)
STRIPE_SECRET_KEY=your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Email (for future use)
RESEND_API_KEY=your_resend_api_key
